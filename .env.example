# ARGUS — Environment Variables
# Copy this file to .env
# No API keys required — everything runs locally via Ollama

# Neo4j local connection (Neo4j Desktop defaults)
NEO4J_URI=bolt://localhost:7400
NEO4J_USER=neo4j
NEO4J_PASSWORD=argus1234

# Ollama (local, no key needed — just needs to be running)
OLLAMA_BASE_URL=http://localhost:11434

# NVD API (optional — increases rate limit from 5 to 50 req/30s)
# Get free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Model names (change if you pull different variants)
LOCAL_MODEL=qwen3:8b
EMBED_MODEL=nomic-embed-text

# Phase 3 only — leave blank until benchmarking
# GROQ_API_KEY=
# CLOUD_MODEL=llama-3.3-70b-versatile
